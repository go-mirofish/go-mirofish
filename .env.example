# LLM API configuration (supports any OpenAI-compatible LLM endpoint)
# Example hosted provider: Google Gemini OpenAI-compatible endpoint
# High-consumption models should be tested with short runs first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.5-flash

# ===== Zep memory graph configuration =====
# The free tier is usually enough for simple usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM configuration (optional) =====
# Remove these keys entirely if you are not using a boost endpoint
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here