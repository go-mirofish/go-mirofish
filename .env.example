# ═══════════════════════════════════════════════════════════════════════════════
# go-mirofish — environment configuration
# Copy to .env, fill in secrets, do NOT commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Primary LLM (required for ontology / profiles / reports) ─────────────────
#
# Any OpenAI-compatible endpoint works.  Examples:
#
#  LM Studio (default port 1234)
#    LLM_BASE_URL=http://127.0.0.1:1234/v1          # direct (no Docker)
#    LLM_BASE_URL=http://host.docker.internal:1234/v1 # inside Docker
#    LLM_API_KEY=local                               # LM Studio ignores the key
#    LLM_MODEL_NAME=qwen2.5-coder-7b-instruct        # model loaded in LM Studio
#
#  Ollama (default port 11434)
#    LLM_BASE_URL=http://127.0.0.1:11434/v1          # direct
#    LLM_BASE_URL=http://host.docker.internal:11434/v1 # inside Docker
#    LLM_API_KEY=local
#    LLM_MODEL_NAME=llama3.1                          # must match `ollama pull` name
#
#  llama.cpp server (default port 8080)
#    LLM_BASE_URL=http://127.0.0.1:8080/v1
#    LLM_BASE_URL=http://host.docker.internal:8080/v1 # inside Docker
#    LLM_API_KEY=local
#    LLM_MODEL_NAME=your-model-alias                  # as reported by /v1/models
#    # Start llama.cpp with: ./llama-server -m model.gguf --port 8080 --ctx-size 8192
#
#  OpenAI
#    LLM_API_KEY=sk-...
#    LLM_BASE_URL=https://api.openai.com/v1
#    LLM_MODEL_NAME=gpt-4o-mini
#
#  Gemini (OpenAI-compatible)
#    LLM_API_KEY=<your Gemini API key>
#    LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#    LLM_MODEL_NAME=gemini-2.5-flash
#
#  xAI / Grok
#    LLM_API_KEY=<your xAI key>
#    LLM_BASE_URL=https://api.x.ai/v1
#    LLM_MODEL_NAME=grok-2-latest
#
#  Groq
#    LLM_API_KEY=<your Groq key>
#    LLM_BASE_URL=https://api.groq.com/openai/v1
#    LLM_MODEL_NAME=llama-3.1-70b-versatile
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.5-flash

# ─── LLM timeout ──────────────────────────────────────────────────────────────
# Default: 300s.  Increase for larger models or slower hardware.
# LLM_TIMEOUT_SECONDS=300

# ─── Auto-discovery ───────────────────────────────────────────────────────────
# The gateway automatically probes well-known local inference server ports
# (Ollama :11434, LM Studio :1234, llama.cpp :8080/:8000) and adds any that
# respond to the fallback pool.  Set to false to disable.
# LLM_AUTODISCOVER=true

# Extra URLs to probe during auto-discovery (comma-separated).
# LLM_DISCOVER_EXTRA_URLS=http://192.168.1.100:11434/v1,http://192.168.1.200:1234/v1

# ─── Boost LLM (optional) ────────────────────────────────────────────────────
# A higher-capability model used as the highest-priority provider.
# Useful for pairing a fast local model (primary) with a cloud model (boost)
# for the most demanding tasks.
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ─── Zep memory graph ─────────────────────────────────────────────────────────
# Free tier: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here
