{
  "name": "go-mirofish",
  "version": "0.1.0",
  "description": "go-mirofish - lightweight and local-first swarm intelligence engine",
  "homepage": "https://gomirofish.vercel.app",
  "scripts": {
    "prepare": "husky",
    "setup": "bash scripts/dev/bootstrap.sh --js-only",
    "setup:all": "bash scripts/dev/bootstrap.sh",
    "dev": "npm run dev --prefix frontend",
    "bootstrap": "bash scripts/dev/bootstrap.sh",
    "gateway": "bash scripts/dev/gateway.sh",
    "frontend": "bash scripts/dev/frontend.sh",
    "build": "bash scripts/dev/frontend.sh build",
    "build:gateway": "bash scripts/dev/gateway.sh build",
    "test": "bash scripts/dev/test.sh",
    "test:go": "bash scripts/dev/test.sh gateway",
    "benchmark": "bash scripts/dev/benchmark.sh",
    "benchmark:live": "bash scripts/dev/benchmark.sh live",
    "benchmark:smoke": "bash scripts/dev/benchmark.sh smoke",
    "clean": "bash scripts/dev/clean.sh",
    "playwright:install": "npx playwright install chromium",
    "release": "bash scripts/release/release.sh",
    "changelog:release": "bash scripts/release/release.sh changelog",
    "release:notes": "bash scripts/release/release.sh notes",
    "changeset": "changeset",
    "commit": "node scripts/commit/cli/index.js commit",
    "commit:dry": "node scripts/commit/cli/index.js commit --dry-run",
    "commit:cli": "node scripts/commit/cli/index.js --help",
    "security:check": "node scripts/commit/security-check.js"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "@changesets/cli": "^2.27.12",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "concurrently": "^9.1.2",
    "husky": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0"
}
