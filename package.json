{
  "name": "go-mirofish",
  "version": "0.1.0",
  "description": "go-mirofish - lightweight and local-first swarm intelligence engine",
  "homepage": "https://gomirofish.vercel.app",
  "scripts": {
    "prepare": "husky",
    "setup": "npm install && npm install --prefix frontend",
    "setup:backend": "node scripts/dev/setup-backend.cjs",
    "setup:all": "npm run setup && npm run setup:backend",
    "dev": "concurrently --kill-others -n \"backend,gateway,frontend\" -c \"green,yellow,cyan\" \"npm run backend\" \"npm run gateway\" \"npm run frontend\"",
    "backend": "node scripts/dev/run-backend.cjs",
    "gateway": "node scripts/dev/run-gateway.cjs",
    "frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "build:gateway": "node scripts/dev/build-gateway.cjs",
    "runtime:static": "python scripts/hybrid/runtime_sprint.py --mode static --no-stack",
    "runtime:sprint": "python scripts/hybrid/runtime_sprint.py --mode all",
    "playwright:install": "npx playwright install chromium",
    "changelog:release": "node scripts/release/update-changelog.cjs",
    "release:notes": "node scripts/release/extract-release-notes.cjs",
    "changeset": "changeset",
    "commit": "node scripts/commit/cli/index.js commit",
    "commit:dry": "node scripts/commit/cli/index.js commit --dry-run",
    "commit:cli": "node scripts/commit/cli/index.js --help",
    "security:check": "node scripts/commit/security-check.js"
  },
  "devDependencies": {
    "playwright": "^1.49.0",
    "@changesets/cli": "^2.27.12",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "concurrently": "^9.1.2",
    "husky": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "AGPL-3.0"
}
