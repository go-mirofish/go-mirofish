#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

# Git hooks often get a minimal PATH (no login shell). Restore common tool locations.
if [ -n "$HOME" ]; then
  export PATH="$PATH:$HOME/.local/bin:$HOME/.cargo/bin"
fi

# Go tests (only if gateway/ exists)
if [ -d "gateway" ]; then
  echo "Running Go tests..."
  (cd gateway && go test ./...)
fi

# Python tests (exit 5 = no tests collected)
echo "Running Python tests..."
(
  cd backend || exit 1
  set +e
  if command -v uv >/dev/null 2>&1; then
    uv run pytest --tb=short -q
  elif [ -x ".venv/bin/python" ]; then
    .venv/bin/python -m pytest --tb=short -q
  elif [ -f ".venv/Scripts/python.exe" ]; then
    .venv/Scripts/python.exe -m pytest --tb=short -q
  else
    echo "pre-push: uv not in PATH and backend/.venv not found — skipping pytest."
    echo "  Fix: install https://docs.astral.sh/uv/ and run: cd backend && uv sync"
    echo "  Or run tests in CI before merging."
    exit 0
  fi
  status=$?
  set -e
  if [ "$status" -eq 5 ]; then
    echo "No tests collected, skipping."
  elif [ "$status" -ne 0 ]; then
    exit "$status"
  fi
)
