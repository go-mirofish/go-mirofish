#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

if [ -n "$HOME" ]; then
  export PATH="$PATH:$HOME/.local/bin:$HOME/.cargo/bin"
fi
if [ -z "$GOCACHE" ]; then
  export GOCACHE="${TMPDIR:-/tmp}/go-build-cache"
fi

if [ -d "gateway" ]; then
  echo "Running Go tests..."
  (cd gateway && go test ./...)
fi
