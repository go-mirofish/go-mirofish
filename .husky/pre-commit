#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

# Git hooks often get a minimal PATH (no login shell).
if [ -n "$HOME" ]; then
  export PATH="$PATH:$HOME/.local/bin:$HOME/.cargo/bin"
fi
if [ -z "$GOCACHE" ]; then
  export GOCACHE="${TMPDIR:-/tmp}/go-build-cache"
fi
if [ -z "$UV_CACHE_DIR" ]; then
  export UV_CACHE_DIR="${TMPDIR:-/tmp}/uv-cache"
fi

# Go: vet (only if gateway/ exists)
if [ -d "gateway" ]; then
  echo "Running go vet..."
  (cd gateway && go vet ./...)
fi

# Python: syntax check on staged files
echo "Checking Python syntax..."
PY_FILES="$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)"
if [ -n "$PY_FILES" ]; then
  cd backend || exit 1
  echo "$PY_FILES" | while IFS= read -r f; do
    [ -z "$f" ] && continue
    [ -f "$ROOT/$f" ] || continue
    if command -v uv >/dev/null 2>&1; then
      if uv run python -c "import sys" >/dev/null 2>&1; then
        uv run python -m py_compile "$ROOT/$f"
      elif command -v python3 >/dev/null 2>&1; then
        python3 -m py_compile "$ROOT/$f"
      elif command -v python >/dev/null 2>&1; then
        python -m py_compile "$ROOT/$f"
      else
        echo "pre-commit: uv is installed but not usable, and no system Python was found; skipping Python syntax check for $f"
      fi
    elif [ -x ".venv/bin/python" ]; then
      .venv/bin/python -m py_compile "$ROOT/$f"
    elif [ -f ".venv/Scripts/python.exe" ]; then
      .venv/Scripts/python.exe -m py_compile "$ROOT/$f"
    elif command -v python3 >/dev/null 2>&1; then
      python3 -m py_compile "$ROOT/$f"
    elif command -v python >/dev/null 2>&1; then
      python -m py_compile "$ROOT/$f"
    else
      echo "pre-commit: uv not in PATH and backend/.venv missing; skipping Python syntax check for $f"
      echo "  Fix: npm run setup:backend  (from repo root)"
      echo "  Or:  cd backend && uv sync  (if uv is installed)"
    fi
  done
  cd "$ROOT" || exit 1
fi
